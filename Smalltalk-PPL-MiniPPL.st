!NormalPrimitive methodsFor: 'as yet unclassified' stamp: 'L.C 7/9/2026 23:13:22'!
applyArguments: arguments onMachine: aMachine atAddress: address

	| distribution rng |
	rng := aMachine instVarNamed: 'randomGenerator'. "esto revisar, ver forma sin meta"
	distribution := NormalDistribution withMean: (arguments at: 1) standardDeviation: (arguments at: 2) randomGenerator: rng.
	
	aMachine pushValue: distribution.! !


